# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID

# REQUIRED in production — the server REFUSES TO START with NODE_ENV=production
# if this is empty or still set to the old built-in default value. It is the
# HMAC key for every session JWT: anyone who knows it can forge a superadmin
# session. Use a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Changing it invalidates all existing sessions (everyone re-logs in once).
APP_SECRET=

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_KIMI_AUTH_URL=       # Kimi OAuth server URL (e.g. https://auth.kimi.com)
VITE_APP_ID=              # OAuth application ID

# ── Backend (Auth) ─────────────────────────────────────────────
KIMI_AUTH_URL=            # Kimi OAuth server URL (backend)
KIMI_OPEN_URL=            # Kimi Open Platform URL (e.g. https://open.kimi.com)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "superadmin" (can create/promote admins)

# ── Bootstrap superadmin ────────────────────────────────────────
# Used ONLY when db.json is created for the very first time. If either value is
# empty the seed is skipped entirely and db.json starts with no accounts — this
# is deliberate, so a fresh install can never come up with a login that is
# published in the source tree. An existing db.json is never re-seeded or
# modified by these values, so changing them does not affect current accounts.
# The password is stored as a bcrypt hash, never as plaintext.
ADMIN_EMAIL=              # e.g. you@example.com
ADMIN_PASSWORD=           # strong, unique; change it after the first login

# ── Development-only escape hatches ─────────────────────────────
# ALLOW_DEV_LOGIN=true enables the credential-free `auth.devLogin` mutation
# (mints any role, including superadmin, with no password) and the fabricated
# mock user that `authenticateRequest` falls back to when the DB is
# unreachable. Both are ignored when NODE_ENV=production. LEAVE THIS UNSET on
# any deployed/reachable environment — NODE_ENV is often unset on shared
# hosting, and this flag is what keeps that from opening the platform.
# ALLOW_DEV_LOGIN=true
